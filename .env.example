# ═══════════════════════════════════════════════════════════════
# DELIRIUM INFINITE - Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Application ─────────────────────────────────────────────
APP_NAME=Delirium Infinite
APP_ENV=development
APP_PORT=8080
APP_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
APP_URL=http://localhost:8080

# ─── Authentication ──────────────────────────────────────────
JWT_SECRET=change-me-to-another-random-string
JWT_EXPIRY_HOURS=24
MASTER_PASSWORD=  # Set on first login via UI

# ─── Default LLM Provider ───────────────────────────────────
# Options: ollama, openai, anthropic, google, alibaba, groq, together, mistral, cohere, custom
DEFAULT_PROVIDER=ollama
ENABLE_AUTO_FALLBACK=true
ENABLE_MULTI_MODEL_CONSENSUS=false

# ─── Ollama (Local) ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:32b

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_DEFAULT_MODEL=gpt-4o

# ─── Anthropic (Claude) ─────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# ─── Google (Gemini) ────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_DEFAULT_MODEL=gemini-1.5-pro

# ─── Alibaba Cloud (Qwen) ───────────────────────────────────
ALIBABA_API_KEY=
ALIBABA_ENDPOINT=https://dashscope.aliyuncs.com/api/v1
ALIBABA_DEFAULT_MODEL=qwen-max

# ─── Groq ────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.1-70b-versatile

# ─── Together AI ─────────────────────────────────────────────
TOGETHER_API_KEY=
TOGETHER_DEFAULT_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# ─── Mistral AI ──────────────────────────────────────────────
MISTRAL_API_KEY=
MISTRAL_DEFAULT_MODEL=mistral-large-latest

# ─── Cohere ──────────────────────────────────────────────────
COHERE_API_KEY=
COHERE_DEFAULT_MODEL=command-r-plus

# ─── Custom OpenAI-Compatible API ───────────────────────────
CUSTOM_API_NAME=
CUSTOM_API_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_API_MODEL=

# ─── Voice / Speech ─────────────────────────────────────────
# STT Engine: whisper_local, groq_whisper, openai_whisper
STT_ENGINE=whisper_local
# TTS Engine: coqui, piper, edge_tts, elevenlabs, google_tts
TTS_ENGINE=edge_tts
TTS_VOICE=pt-BR-AntonioNeural
TTS_SPEED=1.0

# ─── Memory / Database ──────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
REDIS_URL=redis://localhost:6379
SQLITE_PATH=./data/delirium.db

# ─── Integrations ───────────────────────────────────────────
# Gmail
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=

# Google Drive
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── Infrastructure ─────────────────────────────────────────
DOMAIN=localhost
ENABLE_SSL=false
LOG_LEVEL=info
